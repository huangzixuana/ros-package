<launch>
<arg name="gui" default="true" />
    <param name="robot_description" command="$(find xacro)/xacro --inorder '$(find lt_description)/urdf/hangcha_installer.urdf.xacro' use_nominal_extrinsics:=true" />
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

 
    <param name="use_gui" value="$(arg gui)" />
    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" />
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find lt_description)/rviz/hangcha.rviz" required="true" />
</launch>
